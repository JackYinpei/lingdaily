# ==========================================
# Site and authentication
# ==========================================
NEXT_PUBLIC_SITE_URL=http://localhost:8000
AUTH_URL=http://localhost:8000
# Generate with: npx auth secret
AUTH_SECRET=replace_with_a_long_random_value
AUTH_TRUST_HOST=true

# Comma-separated admin email allowlist
ADMIN_EMAILS=admin@example.com

# Optional Google OAuth
# AUTH_GOOGLE_ID=your_google_client_id
# AUTH_GOOGLE_SECRET=your_google_client_secret

# Optional Linux.do OAuth - https://connect.linux.do
# AUTH_LINUXDO_ID=your_linuxdo_client_id
# AUTH_LINUXDO_SECRET=your_linuxdo_client_secret

# ==========================================
# Gemini
# ==========================================
# Canonical server-side key used by Live tokens, translation, scenarios, and podcasts.
GEMINI_API_KEY=replace_with_your_gemini_api_key

# Optional server-side HTTP proxy. GOOGLE_GEMINI_BASE_URL remains a supported
# legacy alias, but new deployments should use GEMINI_BASE_URL.
# GEMINI_BASE_URL=https://api.example.com
# GOOGLE_GEMINI_BASE_URL=https://api.example.com

# Optional browser-visible Gemini Live/WebSocket proxy. This value is embedded
# at image build time. It may point to the same proxy as GEMINI_BASE_URL.
# NEXT_PUBLIC_GEMINI_BASE_URL=https://api.example.com

# Optional legacy key alias and translation model override.
# GOOGLE_API_KEY=replace_with_your_gemini_api_key
# GEMINI_TRANSLATION_MODEL=gemini-2.5-flash

# Never expose a Gemini API key through a NEXT_PUBLIC_* variable.

# ==========================================
# Supabase
# ==========================================
# NEXT_PUBLIC values are intentionally browser-visible and embedded at build time.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server only. Never expose or commit this key.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional server-only aliases/custom schema.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SCHEMA=public

# ==========================================
# Podcast generation
# ==========================================
# POST /api/podcast/generate requires this value in x-podcast-secret.
PODCAST_SECRET=replace_with_a_long_random_value

# Date grouping and container timezone. Defaults to Asia/Shanghai.
PODCAST_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai

# Public RSS/audio base URL. If omitted, NEXT_PUBLIC_SITE_URL is used.
# PODCAST_PUBLIC_URL=https://lingdaily.example.com
# Optional square RSS cover URL; the repository includes a 1400x1400 default.
# PODCAST_IMAGE_URL=https://lingdaily.example.com/podcast-cover.png

# Tencent COS public MP3 storage
TENCENT_COS_SECRET_ID=your_cos_secret_id
TENCENT_COS_SECRET_KEY=your_cos_secret_key
TENCENT_COS_BUCKET=your_bucket-1234567890
TENCENT_COS_REGION=ap-singapore
TENCENT_COS_PODCAST_PREFIX=podcasts
TENCENT_COS_PUBLIC_BASE_URL=https://cdn.example.com
