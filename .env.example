# ==========================================
# 核心配置
# ==========================================
# 发部的时候记得替换成你的生产环境地址
NEXT_PUBLIC_SITE_URL=http://localhost:8000

# ==========================================
# Gemini AI 配置
# ==========================================
# Google API Key，用于 Gemini Live 实时对话
GEMINI_API_KEY=AIzaSy...
# (可选) 如果你需要通过自己的服务器代理 Google 的请求（比如国内用户无法直连），请配置该项
# 配置后客户端的 WebSocket 和 HTTP 请求将通过该地址中转到 Google
# 参考 nginx/gemini-proxy.conf 中的 Nginx 配置
# NEXT_PUBLIC_GEMINI_BASE_URL=https://api.lingdaily.ai

# ==========================================
# 鉴权配置 (NextAuth)
# ==========================================
# 你可以通过 `npx auth secret` 来生成一个新的 AUTH_SECRET
AUTH_SECRET=your_generated_auth_secret_here
AUTH_URL=https://your-domain.com
AUTH_TRUST_HOST=true

# (可选) Linux.do OAuth - https://connect.linux.do
AUTH_LINUXDO_ID=your_linuxdo_client_id
AUTH_LINUXDO_SECRET=your_linuxdo_client_secret

# ==========================================
# 数据库配置 (Supabase)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==========================================
# 播客生成配置 (Podcast)
# ==========================================
# 调用 POST /api/podcast/generate 时必须在 header 里带 x-podcast-secret
PODCAST_SECRET=your_long_random_secret
# (可选) 播客对外访问的基准 URL，写进 RSS 的 enclosure 链接；不填则回退到 NEXT_PUBLIC_SITE_URL
# PODCAST_PUBLIC_URL=https://lingdaily.ai
